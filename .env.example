# ─── Mukesh Unisex Salon — Environment Variables ───
# Copy this file to .env.local (for local dev) or set these in your
# Vercel project settings (Project → Settings → Environment Variables).

# Turso (libSQL) database — your existing seeded database
TURSO_DATABASE_URL=libsql://saloon-uutkarssh.aws-ap-south-1.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# Session signing secret — any long random string.
# Generate one: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-secret

# (Optional) Firebase service account for server-side token verification.
# Not required — the app verifies Firebase ID tokens via Google's public keys.
# If you want to use the Admin SDK instead, set one of these:
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
